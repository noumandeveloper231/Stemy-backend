# Database (Neon Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Auth
JWT_SECRET="replace-with-strong-secret-at-least-16-chars"
JWT_EXPIRES_IN="7d"
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# App URLs
PORT="3000"
# Browser origin where the static client runs (e.g. VS Code Live Server: http://localhost:5500).
# For Stripe checkout return and email links, include a path if your entry page is not at the origin root
# (e.g. http://localhost:5500/client/pages/home.html).
FRONTEND_URL="http://localhost:5500"
APP_BASE_URL="http://localhost:3000"

# Stripe — Checkout uses Price IDs only (price_…), never Product IDs (prod_…).
# Dashboard: Products → select product → Pricing → copy the Price ID for each plan.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_BASIC_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""

# Email (Resend)
RESEND_API_KEY=""
FROM_EMAIL="onboarding@resend.dev"
FROM_NAME="Stemy"

# Queue (BullMQ)
REDIS_URL=""

# Cloudflare R2

# Optional public base URL used for objects returned to frontend, e.g.:
# https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev
# https://cdn.yourdomain.com
R2_PUBLIC_BASE_URL=""
